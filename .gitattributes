* text=auto

# Unix-executed scripts should always check out with LF.
*.sh            text eol=lf
*.py            text eol=lf
*.rb            text eol=lf

# Repository docs and structured text/config files should stay LF.
*.md            text eol=lf
*.json          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.code-snippets text eol=lf
